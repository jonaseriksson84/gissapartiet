# Claude subscription token (preferred — uses your Claude Max/Pro subscription, no per-token billing)
# Get it from your `claude` CLI session.
CLAUDE_CODE_OAUTH_TOKEN=

# Anthropic API key (alternative — pay-per-token API billing)
# Use this only if you don't have a Claude subscription token.
ANTHROPIC_API_KEY=

# GitHub personal access token (must have Issues:RW, Contents:RW, Metadata:R for this repo)
GH_TOKEN=
